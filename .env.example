# Global Space OSINT Operating Centre — Environment Variables
# Copy to .env and fill in your keys

# NASA API key (get free at https://api.nasa.gov)
# DEMO_KEY works but is rate-limited to 30 req/hr
NASA_API_KEY=DEMO_KEY

# N2YO API key (optional, get free at https://www.n2yo.com/api/)
N2YO_API_KEY=
